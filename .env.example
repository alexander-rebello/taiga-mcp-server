# Taiga MCP Server Configuration

# Your Taiga instance URL
export TAIGA_HOST=

# Authentication - use either TOKEN or USERNAME/PASSWORD

# Token-based authentication (preferred)
#TAIGA_TOKEN=your_auth_token_here

# Username and password authentication
export TAIGA_USERNAME=
export TAIGA_PASSWORD=
# Default project ID (used by get_current_project tool)
export DEFAULT_PROJECT_ID=